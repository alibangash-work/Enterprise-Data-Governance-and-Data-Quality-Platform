# Data Governance Platform Configuration

# Environment
ENVIRONMENT=local
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_WORKERS=4

# Data Paths (local development)
BRONZE_PATH=/data/bronze
SILVER_PATH=/data/silver
GOLD_PATH=/data/gold
WAREHOUSE_PATH=/tmp/delta-warehouse

# Spark Configuration
SPARK_MASTER=local[4]
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=2g

# AWS Configuration (for S3)
AWS_REGION=us-east-1
S3_BUCKET=data-governance-bucket
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Database Configuration
DATABASE_URL=postgresql://airflow:airflow@localhost:5432/airflow

# Monitoring Configuration
PROMETHEUS_ENDPOINT=http://localhost:9090
GRAFANA_ENDPOINT=http://localhost:3000
METRICS_PORT=8001

# Metadata/Catalog Configuration
METADATA_HOST=localhost
METADATA_PORT=8585

# Great Expectations Configuration
GE_DIR=/opt/ge
GE_STORE_PATH=/opt/ge/expectations
GE_VALIDATIONS_PATH=/opt/ge/validations

# Feature Flags
ENABLE_LINEAGE=true
ENABLE_QUALITY_CHECKS=true
ENABLE_MONITORING=true

# Airflow Configuration
AIRFLOW_HOME=/opt/airflow
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CELERY__BROKER_URL=redis://localhost:6379/0
